# ╔══════════════════════════════════════════════╗
# ║     SOCIONET — Environment Configuration     ║
# ╚══════════════════════════════════════════════╝
# Copy to .env and fill in ALL values before running

# ── App
NODE_ENV=development
APP_NAME=SOCIONET
APP_URL=http://localhost:3000
APP_VERSION=1.0.0

# ── Ports
API_PORT=4000
REALTIME_PORT=4001
WEB_PORT=3000

# ── Database (PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=socionet
POSTGRES_PASSWORD=CHANGE_ME_strong_password_123
POSTGRES_DB=socionet
DATABASE_URL=postgresql://socionet:CHANGE_ME_strong_password_123@localhost:5432/socionet
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
DATABASE_SSL=false

# ── Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_URL=redis://:CHANGE_ME_redis_password@localhost:6379
REDIS_DB=0
REDIS_KEY_PREFIX=socionet:

# ── JWT Secrets (generate: openssl rand -hex 64)
JWT_SECRET=CHANGE_ME_generate_64_char_random_string_here_openssl_rand_hex_64
JWT_REFRESH_SECRET=CHANGE_ME_generate_another_64_char_random_string_here_different
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ── MinIO (S3-compatible storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=socionet_admin
MINIO_SECRET_KEY=CHANGE_ME_minio_password_strong
MINIO_BUCKET_MEDIA=socionet-media
MINIO_BUCKET_AVATARS=socionet-avatars
MINIO_BUCKET_VIDEOS=socionet-videos
MINIO_BUCKET_AUDIO=socionet-audio
NEXT_PUBLIC_MINIO_URL=http://localhost:9000

# ── Security
BCRYPT_ROUNDS=12
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=10
UPLOAD_RATE_LIMIT_MAX=30
MESSAGE_RATE_LIMIT_MAX=60

# ── Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM=SOCIONET <noreply@socionet.app>
EMAIL_FROM_NAME=SOCIONET

# ── AI (OpenAI)
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=800
OPENAI_TEMPERATURE=0.7

# ── Firebase (Push Notifications)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_STORAGE_BUCKET=

# ── Cloudflare Turnstile (Bot Protection)
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ── Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_REALTIME_URL=http://localhost:4001
NEXT_PUBLIC_APP_NAME=SOCIONET
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Feature Flags
FEATURE_AI_ASSISTANT=true
FEATURE_WALLET=true
FEATURE_LIVE_STREAMING=true
FEATURE_CALLS=true
FEATURE_STORIES=true
FEATURE_REELS=true
FEATURE_COMMUNITIES=true
FEATURE_NEARBY=true

# ── Upload Limits
MAX_IMAGE_SIZE_MB=10
MAX_VIDEO_SIZE_MB=500
MAX_AUDIO_SIZE_MB=50
MAX_FILE_SIZE_MB=100

# ── Content Moderation
AUTO_MODERATION=false
MODERATION_API_KEY=

# ── Analytics (optional)
ANALYTICS_ENABLED=false
POSTHOG_KEY=

# ── Monitoring
SENTRY_DSN=
LOG_LEVEL=info
