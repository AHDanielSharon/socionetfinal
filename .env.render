# ============================================================
# SOCIONET — Render.com Deployment Environment Variables
# Copy these into each Render service's "Environment" tab
# ============================================================

# ── Node
NODE_ENV=production

# ── Server
PORT=4000
API_VERSION=v1

# ── Database (copy from Render PostgreSQL dashboard → "Internal Connection String")
DATABASE_URL=postgresql://user:password@host/dbname

# ── Redis (copy from Render Key Value dashboard → "Internal Redis URL")
REDIS_URL=redis://red-xxxxx:6379

# ── JWT — generate with: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_STRING
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ── Cloudinary (free at cloudinary.com — replaces MinIO)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
USE_CLOUDINARY=true

# ── SMTP Email (use Gmail App Password or Resend.com free tier)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=SOCIONET <your@gmail.com>

# ── App URLs (fill in after Render gives you URLs)
APP_URL=https://socionet-web.onrender.com
API_URL=https://socionet-api.onrender.com
REALTIME_URL=https://socionet-realtime.onrender.com

# ── CORS
CORS_ORIGINS=https://socionet-web.onrender.com,http://localhost:3000

# ── Frontend env vars (for Next.js — prefix with NEXT_PUBLIC_)
NEXT_PUBLIC_API_URL=https://socionet-api.onrender.com/api/v1
NEXT_PUBLIC_REALTIME_URL=https://socionet-realtime.onrender.com
NEXT_PUBLIC_APP_URL=https://socionet-web.onrender.com
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# ── OpenAI (optional — AI assistant)
OPENAI_API_KEY=sk-...

# ── Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
